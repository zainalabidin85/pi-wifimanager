[Unit]
Description=WiFi captive portal manager
After=NetworkManager.service
Wants=NetworkManager.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/pi-wifimanager/wifimanager.py
WorkingDirectory=/opt/pi-wifimanager
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
